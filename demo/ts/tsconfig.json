{
  "files": ["ts_demo.ts"],
  "compilerOptions": {
    "allowJs": false,
    "allowUnreachableCode": false,
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "newLine": "lf",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "rootDir": ".",
    "removeComments": true,
    "sourceMap": true,
    "target": "esnext",
    "strict": true,
    "types": ["node", "websql"]
  }
}
