{
  "name": "lovefield-ts-ts-demo",
  "version": "1.1.0",
  "description": "Demonstrate how to use Lovefield-TS",
  "author": "Arthur Hsu",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf *.js bundle.js *.map",
    "build": "tsc --project tsconfig.json && rollup ts_demo.js --file bundle.js --format iife --name ts_demo -p @rollup/plugin-node-resolve,@rollup/plugin-commonjs",
    "server": "http-server"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/node": "^22.15.3",
    "@types/websql": "0.0.27",
    "http-server": "^14.1.1",
    "lovefield-ts": "^0.8.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.34.6",
    "typescript": "^5.8.3"
  }
}
