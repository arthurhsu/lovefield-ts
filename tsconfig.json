{
  "compilerOptions": {
    "allowJs": false,
    "allowUnreachableCode": false,
    "lib": [
      "dom",
      "es6"
    ],
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "useUnknownInCatchVariables": true,
    "newLine": "lf",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "outDir": "out",
    "rootDir": ".",
    "removeComments": true,
    "sourceMap": true,
    "target": "es6",
    "types": [
      "chai",
      "mocha",
      "node",
      "websql"
    ]
  },
  "exclude": [
    "node_modules",
    "demo",
    "external",
    "dist",
    "tests/harness",
    "scripts"
  ]
}
