{
  "name": "lovefield-ts",
  "version": "0.8.0",
  "description": "Lovefield-TS: a relational database in TypeScript",
  "main": "index.js",
  "module": "dist/lovefield.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf out dist coverage tests/all_tests.ts tests/harness/test_bundle.js tests/harness/test_bundle.js.map",
    "build": "tsc -p tsconfig.json",
    "build:dist": "rollup -c",
    "test": "npm run test:browser",
    "test:node": "npm run build && mocha --require source-map-support/register \"out/tests/**/*.js\" --exclude \"out/tests/**/*_spec.js\" --exclude \"out/tests/*.js\"",
    "test:prepare": "node scripts/gen_all_tests.ts && webpack",
    "test:browser": "npm run build:dist && npm run build && npm run test:prepare && ts-node tests/playwright_runner.ts",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "format": "prettier --write .",
    "pre-commit": "npm run build && npm run lint && npm run format",
    "prepublishOnly": "npm run clean && npm run build:dist"
  },
  "files": [
    "index.js",
    "dist/**"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arthurhsu/lovefield-ts.git"
  },
  "keywords": [
    "relational",
    "database",
    "RDBMS"
  ],
  "author": "Arthur Hsu",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^4.2.14",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.11.18",
    "@types/sinon": "^10.0.13",
    "@types/websql": "0.0.27",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "chai": "^6.2.2",
    "chalk": "^5.2.0",
    "cross-env": "^10.1.0",
    "diff": "^8.0.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fs-extra": "^11.1.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "nopt": "^9.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "sinon": "^19.0.5",
    "source-map-support": "^0.5.19",
    "timers-browserify": "^2.0.12",
    "tiny-lr": "^2.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
