{
  "name": "lovefield-ts",
  "version": "0.7.0",
  "description": "Lovefield-TS: a relational database in TypeScript",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf out dist coverage tests/all_tests.ts tests/harness/test_bundle.js tests/harness/test_bundle.js.map",
    "build": "tsc -p tsconfig.json",
    "build:dist": "rollup -c",
    "test": "npm run test:browser",
    "test:node": "npm run build && mocha --require source-map-support/register \"out/tests/**/*.js\" --exclude \"out/tests/**/*_spec.js\" --exclude \"out/tests/*.js\"",
    "test:prepare": "node scripts/gen_all_tests.ts && webpack",
    "test:browser": "npm run build:dist && npm run build && npm run test:prepare && ts-node tests/selenium_runner.ts",
    "lint": "gts check",
    "fix": "gts fix",
    "pre-commit": "npm run build && npm run lint"
  },
  "files": [
    "index.js",
    "dist/**"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arthurhsu/lovefield-ts.git"
  },
  "keywords": [
    "relational",
    "database",
    "RDBMS"
  ],
  "author": "Arthur Hsu",
  "license": "Apache-2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^4.2.14",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.11.18",
    "@types/selenium-webdriver": "^4.35.5",
    "@types/sinon": "^10.0.13",
    "@types/websql": "0.0.27",
    "chai": "^4.2.0",
    "chalk": "^5.2.0",
    "chromedriver": "^146.0.6",
    "cross-env": "^10.1.0",
    "diff": "^5.1.0",
    "eslint": "^6.8.0",
    "fs-extra": "^11.1.0",
    "glob": "^8.1.0",
    "gts": "^3.1.1",
    "mocha": "^10.2.0",
    "nopt": "^7.0.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "selenium-webdriver": "^4.41.0",
    "sinon": "^15.0.1",
    "source-map-support": "^0.5.19",
    "timers-browserify": "^2.0.12",
    "tiny-lr": "^2.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
